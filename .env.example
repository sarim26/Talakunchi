# ===== AI / Gemini =====
AI_MODE=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ===== Worker scan mode (recon/scanning) =====
# agent = uses Gemini tool-calling (execute_command) for scanning
SCAN_MODE=agent
AGENT_ENABLED=true

# How many Gemini steps per scan (commands run until completion — no wall-clock kill)
AGENT_MAX_STEPS=25

# Optional: comma-separated IPs/CIDRs allowed for the AI to touch.
# If empty, scope becomes effectively just the target IP.
AGENT_SCOPE=

# ===== Hydra credential attacks (used during scan stage in worker) =====
HYDRA_ENABLED=true

# Either set single creds OR use lists below (lists are recommended)
# HYDRA_USERNAME=
# HYDRA_PASSWORD=

# Paths on your SSH Kali machine (Hydra runs there, not in Docker):
HYDRA_USERLIST=/usr/share/seclists/Usernames/cirt-default-usernames.txt
HYDRA_PASSLIST=/usr/share/seclists/Passwords/Common-Credentials/10-million-password-list-top-10000.txt

HYDRA_STOP_ON_FIRST_FIND=false
HYDRA_THREADS=10

# ===== Required: SSH Kali box (every tool runs here; Docker only runs Node) =====
REMOTE_SSH_HOST=192.168.1.50
REMOTE_SSH_USER=kali
REMOTE_SSH_PORT=22
REMOTE_SSH_STRICT_HOST_KEY_CHECKING=accept-new
# Provide one auth method:
#REMOTE_SSH_IDENTITY_FILE=/root/.ssh/id_ed25519
REMOTE_SSH_PASSWORD="replace-with-strong-password-or-use-key-above"

# ===== Nmap scan behavior =====
NMAP_ARGS="-Pn -vvv --reason --stats-every 5s -sV --version-light --top-ports 200"
POLL_INTERVAL_MS=1500

# ===== Phase 4 AI exploitation (optional auto-trigger) =====
# If you don’t want it to auto-run, set to false
EXPLOIT_ENABLED=true

EXPLOIT_MAX_STEPS=15

# If empty, worker allows callbacks on loopback + its local IPv4s.
# To override explicitly, set:  EXPLOIT_LHOST_ALLOWLIST=127.0.0.1,1.2.3.4
EXPLOIT_LHOST_ALLOWLIST=